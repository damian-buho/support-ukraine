{
  "name": "@damian-buho/support-ukraine",
  "version": "1.2.1",
  "type": "module",
  "description": "Browser library that adds a Ukraine-support charity banner to any website.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/"
  ],
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "tsup && tsc --emitDeclarationOnly --noCheck",
    "build:test": "TEST_BUILD=1 tsup",
    "pretest": "npm run build:test",
    "test": "node --test 'dist/test/index.test.js'",
    "test:verbose": "node --test --test-reporter spec 'dist/test/index.test.js'",
    "test:coverage": "node --test --experimental-test-coverage 'dist/test/index.test.js'",
    "audit": "npm audit",
    "check-size": "npx size-limit",
    "prepublishOnly": "npm run build",
    "lint": "eslint ./",
    "fix": "eslint ./ --fix",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts'"
  },
  "keywords": [
    "ukraine",
    "support",
    "anti-war",
    "solidarity"
  ],
  "author": {
    "name": "Damián Búho",
    "email": "damian.buho@proton.me",
    "url": "https://dbuho.me"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/damian-buho/support-ukraine.git"
  },
  "bugs": {
    "url": "https://github.com/damian-buho/support-ukraine/issues"
  },
  "homepage": "https://github.com/damian-buho/support-ukraine#readme",
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@size-limit/preset-small-lib": "12.1.0",
    "@types/eslint": "9.6.1",
    "@types/js-yaml": "4.0.9",
    "@types/node": "26.1.1",
    "esbuild": "0.28.1",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import-x": "4.17.1",
    "eslint-plugin-n": "18.2.2",
    "eslint-plugin-promise": "7.3.0",
    "eslint-plugin-tsdoc": "0.5.2",
    "eslint-plugin-unicorn": "72.0.0",
    "globals": "17.7.0",
    "js-yaml": "5.2.1",
    "prettier": "3.9.5",
    "sass": "1.101.0",
    "size-limit": "12.1.0",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0"
  },
  "prettier": {
    "arrowParens": "avoid",
    "bracketSpacing": true,
    "printWidth": 100,
    "quoteProps": "as-needed",
    "semi": false,
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "none",
    "useTabs": false
  },
  "overrides": {
    "esbuild": "0.28.1",
    "@typescript-eslint/utils": "8.63.0",
    "globals": "$globals"
  },
  "size-limit": [
    {
      "path": "./dist/index.js",
      "limit": "16 kB"
    }
  ]
}
